ANTHROPIC_API_KEY=YOUR-ANTHROPIC-KEY

# 선택: 절대 URL 생성용
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# /news 에 임베드할 기존 보험 뉴스 사이트 URL (미설정 시 코드 기본값 사용)
NEXT_PUBLIC_NEWS_URL=https://insurance-article-five.vercel.app

# /datalab "내 OneDrive에서 Web-Excel 열기" — Microsoft Entra 앱 등록의 클라이언트 ID
